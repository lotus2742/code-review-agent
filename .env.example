# LLM 配置（兼容 OpenAI 接口的服务均可，如 qwen、DeepSeek、OpenAI 等）
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=sk-你的key
OPENAI_MODEL=gpt-4o

# 模型上下文窗口大小（可选，单位：tokens）
# 不填则根据 OPENAI_MODEL 名称自动推断；使用不在推断列表中的模型时建议手动填写
# 例如：qwen-long 为 1000000，llama3-70b 通常为 8192
# MODEL_CONTEXT_TOKENS=128000

# GitHub Token（可选）
# 不填则为只读模式，只能在本地打印 review 结果，无法发回 PR 评论
# 需要 repo 权限，在 GitHub → Settings → Developer settings → Personal access tokens 生成
GITHUB_TOKEN=

